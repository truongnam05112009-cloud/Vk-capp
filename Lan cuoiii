<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<title>NAM HỎI YIP ĐÁP</title>

<style>
body{
margin:0;
height:100vh;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
overflow:hidden;
font-family:sans-serif;
animation:bg 6s infinite alternate;
}
@keyframes bg{
0%{background:#ff758c;}
50%{background:#ff7eb3;}
100%{background:#ffb199;}
}

h1{font-size:60px;color:white;}
h2{font-size:50px;color:white;}

button{
padding:20px 40px;
font-size:26px;
border-radius:30px;
border:none;
margin:10px;
cursor:pointer;
}

#yes{background:#ff3d6d;color:white;}
#no{background:black;color:white;}

.note{color:white;margin-top:10px;}
.hidden{display:none;}

#musicBox{
position:fixed;
top:10px;
left:10px;
font-size:30px;
cursor:pointer;
animation:spin 3s linear infinite;
}
@keyframes spin{
from{transform:rotate(0);}
to{transform:rotate(360deg);}
}

#dog{
position:fixed;
top:50%;
left:50%;
transform:translate(-50%,-50%) scale(0);
width:300px;
z-index:9999;
transition:0.2s;
}
</style>
</head>

<body>

<audio id="bgm" loop>
<source src="music.mp3">
</audio>

<audio id="sad" src="https://www.myinstants.com/media/sounds/sad-violin.mp3"></audio>

<div id="musicBox" onclick="toggleMusic()">🎶</div>

<img id="dog" src="https://i.imgur.com/6o5VQwR.png">

<div id="home">
<h1>💖 NAM HỎI YIP ĐÁP 💖</h1>
<button onclick="start()">Bắt đầu 🚀</button>
</div>

<div id="quiz" class="hidden">
<h2 id="qtext">Bạn thấy nam cute đẳng cấp bro max không? 😏</h2>

<button id="yes" onclick="yesClick()">Có 💕</button>
<button id="no" onclick="noClick()">Không 💀</button>

<div id="note" class="note hidden">
🤑 Nếu muốn Nam xấu xí hãy ấn vào con lợn*
</div>
</div>

<script>
let step=0;
let musicPlaying=false;

let trollSound=new Audio("https://www.myinstants.com/media/sounds/vine-boom.mp3");
let winSound=new Audio("https://www.myinstants.com/media/sounds/anime-wow-sound-effect.mp3");
let scareSound=new Audio("https://www.myinstants.com/media/sounds/scream.mp3");

function start(){
document.getElementById("home").classList.add("hidden");
document.getElementById("quiz").classList.remove("hidden");
document.getElementById("bgm").play();
musicPlaying=true;
}

function toggleMusic(){
let a=document.getElementById("bgm");
if(!musicPlaying){a.play();musicPlaying=true;}
else{a.pause();musicPlaying=false;}
}

function yesClick(){
document.getElementById("quiz").style.display="none";
winSound.play();

// 💥 text
let msg=document.createElement("h1");
msg.innerText="Nam cute: vk anh bá vcl !!! 😎🔥💖";
document.body.appendChild(msg);

// 🐷 hồi sinh nhảy nhẹ
let pig=document.createElement("div");
pig.innerHTML="🐷";
pig.style.position="fixed";
pig.style.left="50%";
pig.style.top="50%";
pig.style.transform="translate(-50%,-50%)";
pig.style.fontSize="60px";
document.body.appendChild(pig);

setInterval(()=>{
pig.style.transform="translate(-50%,-50%) translateY(-20px)";
setTimeout(()=>{
pig.style.transform="translate(-50%,-50%) translateY(0)";
},200);
},400);
}

function noClick(){
step++;

// 🐶 jumpscare
let dog=document.getElementById("dog");
dog.style.transform="translate(-50%,-50%) scale(1.3)";
scareSound.play();
setTimeout(()=>{
dog.style.transform="translate(-50%,-50%) scale(0)";
},500);

// lần 1
if(step===1){
document.getElementById("qtext").innerText="Bạn vẫn muốn chọn không??? 🤨";
return;
}

// hiện note
document.getElementById("note").classList.remove("hidden");

// spam chữ làm ơn🙏🙏🙏
let count=0;
let spam=setInterval(()=>{
let f=document.createElement("div");
f.innerText="Không";
f.style.position="fixed";
f.style.left=Math.random()*90+"%";
f.style.top=Math.random()*90+"%";
f.style.color="white";
document.body.appendChild(f);

setTimeout(()=>f.remove(),500);

count++;
if(count>8){clearInterval(spam);}
},100);

// tạo heo
let noBtn=document.getElementById("no");

setTimeout(()=>{
noBtn.innerHTML="🐷 khônggggg";
noBtn.style.position="fixed";
noBtn.style.cursor="pointer";

let move=setInterval(()=>{
noBtn.style.left=Math.random()*70+"%";
noBtn.style.top=Math.random()*70+"%";
},1200);

// bấm trúng
noBtn.onclick=function(){
clearInterval(move);
noBtn.innerHTML="💀";

// nền tối
document.body.style.background="black";

// nhạc buồn
document.getElementById("sad").play();

// text guilt
let msg=document.createElement("div");
msg.innerHTML="Bạn đã giết nó... 😭<br>Hãy ấn Có để cứu nó...";
msg.style.position="fixed";
msg.style.top="60%";
msg.style.left="50%";
msg.style.transform="translateX(-50%)";
msg.style.color="white";
msg.style.fontSize="28px";
document.body.appendChild(msg);
};

},800);
}
</script>

</body>
</html>
